{
  "name": "@paylix/sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for accepting USDC payments and subscriptions via Paylix on Base.",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/JanoTheDev/paylix.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "crypto",
    "payments",
    "usdc",
    "base",
    "subscriptions",
    "web3",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "viem": "^2"
  },
  "devDependencies": {
    "@paylix/config": "workspace:*",
    "@types/node": "25.6.0",
    "tsup": "^8",
    "typescript": "^5.5",
    "vitest": "^4.1.5"
  }
}
